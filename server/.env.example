# ——— HELIO Solar Grid — Environment Variables ———

# MongoDB Atlas URI (replace with your connection string)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/helio_solar?retryWrites=true&w=majority

# OpenWeatherMap API key (free tier works)
# Get it at: https://openweathermap.org/api
OWM_API_KEY=your_openweathermap_api_key_here

# Grid location (defaults to Hyderabad)
LAT=17.3850
LON=78.4867

# Server config
PORT=5000
CLIENT_URL=http://localhost:3000

# JWT Secret (for future auth)
JWT_SECRET=your_super_secret_key_here
